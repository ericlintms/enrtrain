<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- 修改此項以指定範例主程式 -->
    <StartupObject>SemanticKernelAgentDemo</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Microsoft.SemanticKernel 核心：包含 Kernel、Plugin、ChatHistory
      以及 OpenAI / OpenAI-compatible (Ollama) 連接器。
      執行前請確認版本為最新穩定版：
        dotnet add package Microsoft.SemanticKernel
    -->
    <PackageReference Include="Microsoft.SemanticKernel" Version="1.28.0" />
  </ItemGroup>

</Project>
